<UserControl x:Class="ReVM.ToastNotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="54"
             RenderTransformOrigin="0.5,1">
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="ToastTranslate" Y="28"/>
    </UserControl.RenderTransform>

    <Border x:Name="ToastRoot"
            Width="{Binding Width}"
            Background="#F01E1E1E"
            BorderThickness="1"
            Padding="10,8,12,8"
            Opacity="0">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#3E3E3E"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsError}" Value="True">
                        <Setter Property="BorderBrush" Value="#6A2C2C"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>

            <Path x:Name="IconPath"
                  Data="{Binding IconData}"
                  StrokeThickness="1.0"
                  Fill="Transparent"
                  Width="15"
                  Height="15"
                  Stretch="Uniform"
                  VerticalAlignment="Top"
                  Margin="0,1,0,0">
                <Path.Style>
                    <Style TargetType="Path">
                        <Setter Property="Stroke" Value="#CCCCCC"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Stroke" Value="#F48771"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Path.Style>
            </Path>

            <StackPanel Grid.Column="1" Margin="5,0,14,0">
                <TextBlock Text="{Binding Title}"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Message}"
                           Foreground="#858585"
                           FontSize="10"
                           Margin="0,2,0,7"
                           TextTrimming="CharacterEllipsis"/>
                <Grid x:Name="ProgressTrack" Height="2" Background="#2D2D2D">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowProgress}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border x:Name="ProgressFill" HorizontalAlignment="Left" Width="0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#858585"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                        <Setter Property="Background" Value="#F48771"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </StackPanel>

            <Button Grid.Column="2"
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Cursor="Hand"
                    Click="Dismiss_Click"
                    ToolTip="Dismiss">
                <Path Data="M4,4 L12,12 M12,4 L4,12"
                      Stroke="#858585"
                      StrokeThickness="1.15"
                      Width="9"
                      Height="9"
                      Stretch="Uniform"/>
            </Button>
        </Grid>
    </Border>
</UserControl>
