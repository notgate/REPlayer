<Window x:Class="ReVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReVM"
        Title="REPlayer" Height="746" Width="1310"
        WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        Background="#1E1E1E">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="26" ResizeBorderThickness="6"
                       GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- VS Code tooltip -->
        <Style x:Key="VscodeToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#454545"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apply VS Code tooltip style to ALL tooltips in this window -->
        <Style TargetType="ToolTip" BasedOn="{StaticResource VscodeToolTip}"/>

        <!-- Context menu item (used everywhere: overflow, instances, settings) -->
        <Style x:Key="CtxItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toolbar icon -->
        <Style x:Key="ToolIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#858585"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <Grid>
                                <Border x:Name="ActiveBar" Background="Transparent"
                                        Width="2" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="ActiveBar" Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2D2E37"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3B46"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25262F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window button (no hand cursor) -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E3E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Compact VS Code-style instance row -->
        <DataTemplate x:Key="InstanceCardTemplate">
            <Border Background="#252526" BorderBrush="#333333" BorderThickness="0,0,0,1"
                    Padding="8,7" Cursor="Hand" MouseLeftButtonDown="Instance_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="74"/>
                        <ColumnDefinition Width="24"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="7" Height="7" Fill="#858585" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" Foreground="#D4D4D4" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding BootProfile}" Foreground="#858585" FontFamily="Cascadia Mono, Consolas" FontSize="10"/>
                            <TextBlock Text="  ·  " Foreground="#555555" FontSize="10"/>
                            <TextBlock Text="{Binding CpuCount, StringFormat={}{0}c}" Foreground="#A6A6A6" FontFamily="Cascadia Mono, Consolas" FontSize="10"/>
                            <TextBlock Text=" / " Foreground="#555555" FontSize="10"/>
                            <TextBlock Text="{Binding RamMB, StringFormat={}{0}m}" Foreground="#A6A6A6" FontFamily="Cascadia Mono, Consolas" FontSize="10"/>
                            <TextBlock Text=" / " Foreground="#555555" FontSize="10"/>
                            <TextBlock Text="{Binding StorageGB, StringFormat={}{0}g}" Foreground="#A6A6A6" FontFamily="Cascadia Mono, Consolas" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding Status}" Foreground="#A6A6A6" FontSize="10" FontFamily="Cascadia Mono, Consolas" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="6,3" Cursor="Hand" VerticalAlignment="Center"
                            Click="DeleteInstance_Click" Tag="{Binding Id}" ToolTip="Stop instance">
                        <Path Data="M2,2 L10,10 M10,2 L2,10" Stroke="#858585" StrokeThickness="1.25" Width="8" Height="8" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>
        <Storyboard x:Key="Entrance"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="#323233">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="REPlayer" Foreground="#CCCCCC" FontSize="11"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
            <StackPanel x:Name="stackPanel" Grid.Column="1" Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="TitleMenuBtn" Style="{StaticResource WinBtn}" Click="TitleMenu_Click" ToolTip="Menu">
                    <Path Data="M3,4 L13,4 M3,8 L13,8 M3,12 L13,12" Stroke="#CCCCCC" StrokeThickness="1"
                          Width="11" Height="11" Stretch="Uniform"/>
                </Button>
                <Button x:Name="MiniModeBtn" Style="{StaticResource WinBtn}" Click="MiniMode_Click" ToolTip="Mini mode">
                    <Path Data="M3,5 L13,5 L13,11 L3,11 Z M5,7 L9,7" Stroke="#CCCCCC" StrokeThickness="1"
                          Fill="Transparent" Width="11" Height="11" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource WinBtn}" Click="Minimize_Click" ToolTip="Minimize">
                    <Path Data="M0,10 L10,10" Stroke="#CCCCCC" StrokeThickness="1"
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
                <Button x:Name="MaxBtn" Style="{StaticResource WinBtn}" Click="Maximize_Click" ToolTip="Maximize">
                    <Path x:Name="MaxIcon" Data="M2,2 L12,2 L12,12 L2,12 Z" Stroke="#CCCCCC"
                          StrokeThickness="1" Fill="Transparent"
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource CloseBtn}" Click="Close_Click" ToolTip="Close">
                    <Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1"
                          Width="10" Height="10" Stretch="Uniform"/>
                </Button>
                <Button x:Name="CollapseChromeBtn" Style="{StaticResource WinBtn}" Click="CollapseSidebar_Click" ToolTip="Collapse sidebar">
                    <Path x:Name="CollapseIcon" Data="M11,3 L6,8 L11,13 M7,3 L2,8 L7,13" Stroke="#CCCCCC" StrokeThickness="1.2"
                          Fill="Transparent" Width="12" Height="10" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid x:Name="grid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="ToolbarColumn" Width="30"/>
            </Grid.ColumnDefinitions>

            <!-- Display -->
            <Border Grid.Column="0" Background="#0D0D0D" ClipToBounds="True" SnapsToDevicePixels="True">
                <Grid ClipToBounds="True" SnapsToDevicePixels="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition x:Name="DebugStatusRow" Height="118"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="DisplayViewport" Grid.Row="0" Background="#0D0D0D" ClipToBounds="True"
                            HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True">
                        <Grid ClipToBounds="True" SnapsToDevicePixels="True">
                            <local:NativeChildHost x:Name="DisplayHost"/>
                            <Image x:Name="FramePreview" Visibility="Collapsed"
                                   Stretch="Uniform" SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="LowQuality"/>
                            <StackPanel x:Name="NoVmOverlay"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="REPlayer" Foreground="#2D2D2D" FontSize="48"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Android Emulator for Security Research"
                                           Foreground="#252526" FontSize="13"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="StatusBar" Grid.Row="1" VerticalAlignment="Top" Background="#007ACC" Height="26" Padding="10,0">
                        <TextBlock x:Name="StatusText" Text="Ready" Foreground="White"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Border x:Name="RendererDebugPanel" Grid.Row="1" Margin="0,26,0,0" Background="#111111" BorderBrush="#252526" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#171717" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="ADB" Foreground="#858585" FontSize="10" FontWeight="SemiBold" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="AdbReadinessText" Text="not checked" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="10" Width="92"/>
                                    <TextBlock Text="FASTPIPE" Foreground="#858585" FontSize="10" FontWeight="SemiBold" Margin="12,0,6,0"/>
                                    <TextBlock x:Name="FastpipeReadinessText" Text="waiting" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="10" Width="88"/>
                                    <TextBlock Text="GPU" Foreground="#858585" FontSize="10" FontWeight="SemiBold" Margin="12,0,6,0"/>
                                    <TextBlock x:Name="GpuSourceText" Text="pending" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="10" Width="120"/>
                                    <TextBlock Text="BOOT" Foreground="#858585" FontSize="10" FontWeight="SemiBold" Margin="12,0,6,0"/>
                                    <TextBlock x:Name="AndroidReadinessText" Text="pending" Foreground="#DCDCAA" FontFamily="Consolas" FontSize="10" Width="130"/>
                                    <TextBlock x:Name="ReadinessHintText" Text="route/ADB diagnostic pending" Foreground="#858585" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <TextBlock x:Name="RendererDebugText" Text="Renderer debug log ready"
                                           Foreground="#9CDCFE" FontFamily="Consolas" FontSize="10"
                                           TextWrapping="NoWrap" Padding="10,6,10,8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border x:Name="BootProgressOverlay" Grid.Row="0" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#111518" Panel.ZIndex="20" ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <!-- Clean-room LDPlayer-style startup surface: dark abstract ribbons, centered mark, bottom hairline progress. -->
                            <Canvas IsHitTestVisible="False" Opacity="1">
                                <Rectangle Width="2400" Height="1400" Fill="#15191C"/>
                                <Path Data="M-160,110 C120,235 280,55 560,148 C845,242 982,38 1260,88 C1545,140 1670,365 1970,292 C2170,244 2320,285 2520,370 L2520,0 L-160,0 Z"
                                      Fill="#0D1013" Opacity="0.92" Stretch="Fill" Width="1600" Height="240" Canvas.Top="0"/>
                                <Path Data="M-110,270 C185,390 350,245 620,335 C900,428 1035,238 1295,320 C1588,412 1682,680 1970,612 C2185,560 2345,640 2520,790 L2520,210 L-110,210 Z"
                                      Fill="#202529" Opacity="0.72" Stretch="Fill" Width="1700" Height="520" Canvas.Top="45"/>
                                <Path Data="M-160,420 C110,485 290,360 540,455 C848,573 1010,370 1280,462 C1560,558 1680,822 1970,770 C2180,734 2360,845 2520,980 L2520,1040 L-160,1040 Z"
                                      Fill="#0B0E11" Opacity="0.72" Stretch="Fill" Width="1700" Height="680" Canvas.Top="165"/>
                                <Path Data="M-180,650 C95,570 240,685 415,620 C620,544 765,720 985,742 C1255,770 1405,642 1668,762 C1900,870 2130,790 2520,1015 L2520,1250 L-180,1250 Z"
                                      Fill="#252A2E" Opacity="0.58" Stretch="Fill" Width="1700" Height="560" Canvas.Top="310"/>
                            </Canvas>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,42">
                                <Grid Width="42" Height="42" Margin="0,0,12,0">
                                    <Ellipse Stroke="#F2F2F2" StrokeThickness="6"/>
                                    <Path Data="M20,8 L12,24 L22,24 L18,35 L32,17 L22,17 Z" Fill="#F2F2F2" Stretch="Uniform" Width="25" Height="29" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="REPLAYER" Foreground="#F2F2F2" FontFamily="Segoe UI Black, Segoe UI" FontSize="33" FontWeight="Black" FontStyle="Italic" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid VerticalAlignment="Bottom" Height="28" Background="#CC050607">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2"/>
                                    <RowDefinition Height="26"/>
                                </Grid.RowDefinitions>
                                <Canvas x:Name="BootProgressCanvas" Grid.Row="0" Height="18" VerticalAlignment="Top" ClipToBounds="False">
                                    <Border x:Name="BootProgressTrack" Height="2" Background="#292D31" Width="1"/>
                                    <Border x:Name="BootProgressFill" Height="2" Background="#C8C8C8" Width="0"/>
                                    <Border x:Name="BootProgressPercentPill" Canvas.Top="-8" Width="34" Height="16" Background="#F1F1F1" CornerRadius="4">
                                        <TextBlock x:Name="BootProgressPercent" Text="0%" Foreground="#080A0B" FontFamily="Cascadia Mono, Consolas" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Canvas>
                                <Grid Grid.Row="1" Margin="7,0,7,0">
                                    <TextBlock Text="Select a target package before capturing traffic, logs, files, and hooks." Foreground="#B6B6B7" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="BootProgressLabel" Text="Starting up" Foreground="#B6B6B7" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                                    <TextBlock Text="REPlayer" Foreground="#858585" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right toolbar -->
            <Border x:Name="RightToolbar" Grid.Column="1" Background="#252526">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <Button Style="{StaticResource ToolIcon}" Click="Settings_Click" ToolTip="Settings" Margin="0,4,0,0">
                                <Path Data="M8,3 A2,2 0 1,0 8,7 A2,2 0 1,0 8,3 Z M8,7 L8,13 M3,5 L5,3 M11,13 L13,11 M3,11 L5,13 M11,3 L13,5" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="ToggleInstances_Click" ToolTip="Instances">
                                <Path Data="M3,3 L13,3 L13,5 L3,5 Z M3,7 L13,7 L13,9 L3,9 Z M3,11 L13,11 L13,13 L3,13 Z" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="AgentCenter_Click" ToolTip="Agent Center">
                                <Path Data="M3,3 L6,3 L6,6 L3,6 Z M10,3 L13,3 L13,6 L10,6 Z M6.5,10 L9.5,10 L9.5,13 L6.5,13 Z M6,4.5 L10,4.5 M8,4.5 L8,10" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button x:Name="DebugToggleBtn" Style="{StaticResource ToolIcon}" Click="ToggleDebugStrip_Click" ToolTip="Show / hide debug strip" Tag="Active">
                                <Path x:Name="DebugStripIcon" Data="M3,4 L13,4 L13,12 L3,12 Z M5,7 L11,7 M5,9 L9,9" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="KeyboardMapping_Click" ToolTip="Keyboard Mapping">
                                <Path Data="M2,4 L14,4 L14,12 L2,12 Z M4,6 L5,6 M7,6 L8,6 M10,6 L11,6 M4,8 L5,8 M7,8 L8,8 M10,8 L11,8 M5,10 L11,10" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="VolumeUp_Click" ToolTip="Volume +">
                                <Path Data="M2,7 L5,7 L9,3 L9,13 L5,9 L2,9 Z M11,5 L11,11 M8,8 L14,8" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="VolumeDown_Click" ToolTip="Volume -">
                                <Path Data="M2,7 L5,7 L9,3 L9,13 L5,9 L2,9 Z M11,8 L14,8" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="FullScreen_Click" ToolTip="Full Screen">
                                <Path Data="M2,6 L2,2 L6,2 M10,2 L14,2 L14,6 M14,10 L14,14 L10,14 M6,14 L2,14 L2,10" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="InjectApk_Click" ToolTip="Install APK">
                                <Path Data="M4,2 L12,2 L14,4 L14,14 L2,14 L2,4 Z M4,2 L4,4 L2,4 M6,7 L10,7 M8,5 L8,11" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="Screenshot_Click" ToolTip="Screenshot">
                                <Path Data="M2,4 L5,2 L11,2 L14,4 L14,12 L2,12 Z M8,5 A3,3 0 1,0 8,11 A3,3 0 1,0 8,5 Z" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="VideoRecorder_Click" ToolTip="Video Recorder">
                                <Path Data="M3,5 L10,5 L10,11 L3,11 Z M10,7 L14,5 L14,11 L10,9 Z" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="SpoofGps_Click" ToolTip="Virtual GPS">
                                <Path Data="M8,2 A6,6 0 1,0 8,14 A6,6 0 1,0 8,2 Z M8,5 A3,3 0 1,1 8,11 A3,3 0 1,1 8,5 Z" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="ToggleOrientation_Click" ToolTip="Switch portrait / landscape profile"
                                    AutomationProperties.Name="Switch portrait / landscape profile"
                                    AutomationProperties.AutomationId="OrientationProfileButton">
                                <Path x:Name="OrientIcon" Data="M5,2 L11,2 L11,14 L5,14 Z M7,13 L9,13 M2,8 A6,6 0 1,1 13,4 M13,4 L13,7 M13,4 L10,4" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource ToolIcon}" Click="FlipScreen_Click" ToolTip="Flip guest screen orientation">
                                <Path Data="M8,2 L13,5 L8,8 L3,5 Z M13,5 L13,11 L8,14 L8,8 M3,5 L3,11 L8,14" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Margin="0,0,0,4">
                        <Border Background="#3E3E3E" Height="1" Margin="6,2"/>
                        <Button Style="{StaticResource ToolIcon}" Click="AndroidBack_Click" ToolTip="Back">
                            <Path Data="M10,3 L5,8 L10,13 M5,8 L14,8" Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ToolIcon}" Click="AndroidHome_Click" ToolTip="Home">
                            <Path Data="M3,8 L8,3 L13,8 M5,7 L5,13 L11,13 L11,7" Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                        </Button>
                        <Button Style="{StaticResource ToolIcon}" Click="AndroidAppSwitcher_Click" ToolTip="App Switcher">
                            <Path Data="M4,4 L12,4 L12,10 L4,10 Z M2,7 L10,7 L10,13 L2,13 Z" Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="13" Height="13" Stretch="Uniform"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Popup x:Name="AndroidBootToastPopup"
               PlacementTarget="{Binding ElementName=DisplayViewport}"
               Placement="Relative"
               AllowsTransparency="True"
               StaysOpen="True"
               IsOpen="False"
               Panel.ZIndex="1000">
            <local:ToastNotificationControl x:Name="AndroidBootToastView" DismissRequested="CloseBootToast_Click"/>
        </Popup>

        <Popup x:Name="ApkInstallToastPopup"
               PlacementTarget="{Binding ElementName=DisplayViewport}"
               Placement="Relative"
               AllowsTransparency="True"
               StaysOpen="True"
               IsOpen="False"
               Panel.ZIndex="1001">
            <local:ToastNotificationControl x:Name="ApkInstallToastView" DismissRequested="CloseApkInstallToast_Click"/>
        </Popup>

        <!-- Bottom toolbar (horizontal) -->
        <Border x:Name="BottomToolbar" Grid.Row="2" Background="#252526" Height="30" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource ToolIcon}" Click="ToggleEngine_Click">
                    <Ellipse Width="7" Height="7" Fill="#4EC9B0"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="NewInstance_Click">
                    <Path Data="M6,2 L14,2 L14,14 L6,14 Z M9,6 L11,6 M10,5 L10,7"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="ToggleInstances_Click">
                    <Path Data="M3,3 L13,3 L13,5 L3,5 Z M3,7 L13,7 L13,9 L3,9 Z M3,11 L13,11 L13,13 Z"
                          Stroke="#858585" StrokeThickness="1.2" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button x:Name="BottomDebugToggleBtn" Style="{StaticResource ToolIcon}" Click="ToggleDebugStrip_Click" ToolTip="Show / hide debug strip" Tag="Active">
                    <Path x:Name="BottomDebugStripIcon" Data="M3,4 L13,4 L13,12 L3,12 Z M5,7 L11,7 M5,9 L9,9"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Border Background="#3E3E3E" Width="1" Height="20" Margin="4,0"/>
                <Button Style="{StaticResource ToolIcon}" Click="Adb_Click">
                    <Path Data="M3,3 L13,3 L13,13 L3,13 Z M5,6 L11,6 M8,6 L8,10"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="SpoofGps_Click">
                    <Path Data="M8,2 A6,6 0 1,0 8,14 A6,6 0 1,0 8,2 Z M8,5 A3,3 0 1,1 8,11 A3,3 0 1,1 8,5 Z"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="Screenshot_Click">
                    <Path Data="M2,4 L5,2 L11,2 L14,4 L14,12 L2,12 Z M8,5 A3,3 0 1,0 8,11 A3,3 0 1,0 8,5 Z"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="InjectApk_Click">
                    <Path Data="M4,2 L12,2 L14,4 L14,14 L2,14 L2,4 Z M4,2 L4,4 L2,4 M6,7 L10,7 M8,5 L8,11"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Border Background="#3E3E3E" Width="1" Height="20" Margin="4,0"/>
                <Button Style="{StaticResource ToolIcon}" Click="ToggleOrientation_Click" ToolTip="Switch portrait / landscape profile"
                        AutomationProperties.Name="Switch portrait / landscape profile"
                        AutomationProperties.AutomationId="BottomOrientationProfileButton">
                    <Path Data="M4,2 L10,2 L10,14 L4,14 Z M5.5,12.5 L8.5,12.5 M11.5,4.5 L14,7 L11.5,9.5 M14,7 L11,7" Stroke="#858585" StrokeThickness="1.2"
                          Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="FlipScreen_Click" ToolTip="Flip guest screen orientation">
                    <Path Data="M8,2 L13,5 L8,8 L3,5 Z M13,5 L13,11 L8,14 L8,8 M3,5 L3,11 L8,14" Stroke="#858585" StrokeThickness="1.2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                </Button>
                <Button Style="{StaticResource ToolIcon}" Click="Settings_Click">
                    <Path Data="M8,3 A2,2 0 1,0 8,7 A2,2 0 1,0 8,3 Z M8,7 L8,13 M3,5 L5,3 M11,13 L13,11 M3,11 L5,13 M11,3 L13,5"
                          Stroke="#858585" StrokeThickness="1.2" Fill="Transparent"
                          Width="14" Height="14" Stretch="Uniform"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Instances popup with inline add-instance form -->
        <Popup x:Name="InstancePopup" PlacementTarget="{Binding ElementName=TitleMenuBtn}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1" Width="386" MaxHeight="520" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.42" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="188"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#252526" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="10,0">
                        <TextBlock Text="Instances" Foreground="#D4D4D4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Grid Grid.Row="1" Background="#1E1E1E">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="74"/>
                            <ColumnDefinition Width="24"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="NAME" Foreground="#858585" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="STATE" Foreground="#858585" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <ScrollViewer Grid.Row="2" MaxHeight="260" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="InstanceList" ItemTemplate="{StaticResource InstanceCardTemplate}"/>
                    </ScrollViewer>
                    <Border Grid.Row="3" Background="#252526" BorderBrush="#333333" BorderThickness="0,1,0,0" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Add instance" Foreground="#D4D4D4" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="128"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InlineInstanceNameBox" Text="Android" Height="24" Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" BorderThickness="1" Padding="7,2" FontSize="11" CaretBrush="#CCCCCC"/>
                                <ComboBox x:Name="InlineInstanceProfileCombo" Grid.Column="1" Height="24" Margin="6,0,0,0" Background="#1E1E1E" Foreground="#CCCCCC" BorderBrush="#3C3C3C" FontSize="11" SelectedIndex="0">
                                    <ComboBoxItem Content="Release" Tag="api34-persona"/>
                                    <ComboBoxItem Content="Resizable" Tag="api34-resizable"/>
                                    <ComboBoxItem Content="Play" Tag="play-compat"/>
                                </ComboBox>
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CPU" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/>
                                <Slider x:Name="InlineCpuSlider" Grid.Column="1" Minimum="1" Maximum="4" Value="2" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=InlineCpuSlider, Path=Value, StringFormat={}{0:F0}}" Foreground="#CCCCCC" FontFamily="Cascadia Mono, Consolas" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Grid.Row="3" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RAM" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/>
                                <Slider x:Name="InlineRamSlider" Grid.Column="1" Minimum="1024" Maximum="4096" Value="2048" TickFrequency="1024" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=InlineRamSlider, Path=Value, StringFormat={}{0:F0}m}" Foreground="#CCCCCC" FontFamily="Cascadia Mono, Consolas" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="72"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Data" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/>
                                <Slider x:Name="InlineStorageSlider" Grid.Column="1" Minimum="8" Maximum="32" Value="8" TickFrequency="8" IsSnapToTickEnabled="True"/>
                                <TextBlock Grid.Column="2" Text="{Binding ElementName=InlineStorageSlider, Path=Value, StringFormat={}{0:F0}g}" Foreground="#CCCCCC" FontFamily="Cascadia Mono, Consolas" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Add" Click="NewInstance_Click" Height="26" Margin="8,0,0,0" Style="{StaticResource DialogButton}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Popup>

        <!-- Overflow context menu -->
        <Popup x:Name="OverflowPopup" PlacementTarget="{Binding ElementName=TitleMenuBtn}"
               Placement="Left" StaysOpen="False" AllowsTransparency="True">
            <Border Background="#252526" BorderBrush="#454545" BorderThickness="1"
                    CornerRadius="6" Padding="4" MinWidth="170">
                <StackPanel>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="Adb_Click">
                        <TextBlock Text="ADB Shell" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="SpoofGps_Click">
                        <TextBlock Text="GPS Spoofing" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="Screenshot_Click">
                        <TextBlock Text="Screenshot" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="InjectApk_Click">
                        <TextBlock Text="Install APK" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="AgentCenter_Click">
                        <TextBlock Text="Agent Center" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>

                    <Border Background="#3E3E3E" Height="1" Margin="4,2"/>
                    <Border Style="{StaticResource CtxItem}" MouseLeftButtonDown="Settings_Click">
                        <TextBlock Text="Settings" Foreground="#CCCCCC" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
