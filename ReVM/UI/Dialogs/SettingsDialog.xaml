                                        <Grid Height="36"><TextBlock Text="Keep window on top in mini mode" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="MiniTopMostToggle" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
                                        <Grid Height="36"><TextBlock Text="Show compact right toolbar" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="CompactToolbarToggle" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
                                        <Grid Height="36"><TextBlock Text="Keep launcher visible during cold boot" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="ColdBootLauncherToggle" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
                                        <TextBlock Text="Cold boots remain in the setup launcher with monotonic progress. REPlayer enters the emulator only after Android and its control channel are ready." Style="{StaticResource SettingHint}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel></ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="0,14,28,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource LdButton}" Width="80" Height="28" Padding="0" Margin="0,0,10,0"/>
                    <Button Content="Apply" Click="Apply_Click" Style="{StaticResource LdButton}" Width="80" Height="28" Padding="0" Margin="0,0,10,0"/>
                    <Button Content="Save" Click="Save_Click" Style="{StaticResource BlueButton}" Width="80" Height="28" Padding="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
