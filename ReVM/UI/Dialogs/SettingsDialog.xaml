                                            <Grid Height="31" Margin="0,10,0,0"><TextBlock Text="Full emulator network speed" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="NatToggle" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
