                                            <Grid Height="31"><TextBlock Text="Block host services / 10.0.2.2" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="BlockHostServicesToggle" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
                                            <Grid Height="31"><TextBlock Text="Block private and CGNAT ranges" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="BlockPrivateNetworksToggle" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
                                            <Grid Height="31"><TextBlock Text="Block link-local and metadata ranges" Style="{StaticResource SettingLabel}"/><CheckBox x:Name="BlockLinkLocalToggle" HorizontalAlignment="Right" Style="{StaticResource SwitchCheck}"/></Grid>
