                                            <TextBlock Text="Internet-only uses all destination blocks. Select Custom to change them individually. Applying these host-policy toggles requires UAC." Style="{StaticResource SettingHint}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,22,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="146"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
