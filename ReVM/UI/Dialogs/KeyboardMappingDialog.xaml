<Window x:Class="ReVM.KeyboardMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Mapping" Height="556" Width="736"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterOwner">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="26" ResizeBorderThickness="4" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgPanel" Color="#252526"/>
        <SolidColorBrush x:Key="BgTitle" Color="#323233"/>
        <SolidColorBrush x:Key="BgCard" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgHover" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#858585"/>

        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3E3E3E"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="62"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#858585"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="4">
                            <StackPanel VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="{TemplateBinding Foreground}" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/><Setter Property="Foreground" Value="#CCCCCC"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Margin="0,-1,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3E3E3E"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#252526"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#37373D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#29292E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="10,3,10,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource BgTitle}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Path Data="M2,4 L14,4 L14,12 L2,12 Z M4,6 L5,6 M7,6 L8,6 M10,6 L11,6 M5,10 L11,10" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="13" Height="13" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="Keyboard Mapping" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseBtn}" Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0D0D0D" BorderBrush="#14181F" BorderThickness="0,0,1,0">
                    <Grid>
                        <TextBlock Text="Drag controls from the right panel onto the Android screen"
                                   Foreground="#5A5A5A" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="230" Height="110" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,80,0,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="WASD" Foreground="#858585" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="movement pad preview" Foreground="#5A5A5A" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource BgPanel}">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="20,22,20,20">
                            <TextBlock Text="PRESET" Foreground="#858585" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Config" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="Default" Style="{StaticResource FieldBox}"/>
                            </Grid>
                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Group" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="General" Style="{StaticResource FieldBox}"/>
                            </Grid>

                            <TextBlock Text="DRAG CONTROLS" Foreground="#858585" FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                            <UniformGrid Columns="4" Rows="3" Margin="0,0,0,24">
                                <Button Style="{StaticResource ToolButton}" Tag="Tap"><Path Data="M8,2 A6,6 0 1,0 8,14 A6,6 0 1,0 8,2 Z M8,6 L8,10 M6,8 L10,8" Stroke="#858585" StrokeThickness="1.1" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Move"><Path Data="M8,2 L8,14 M2,8 L14,8 M5,5 L8,2 L11,5 M5,11 L8,14 L11,11" Stroke="#858585" StrokeThickness="1.1" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Aim"><Path Data="M8,2 L8,5 M8,11 L8,14 M2,8 L5,8 M11,8 L14,8 M5,5 A4,4 0 1,0 11,11 A4,4 0 1,0 5,5" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Fire"><Path Data="M8,2 L10,7 L14,8 L10,10 L8,14 L6,10 L2,8 L6,7 Z" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Swipe"><Path Data="M3,11 C6,4 10,4 13,8 M10,8 L13,8 L13,5" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Macro"><Path Data="M3,4 L13,4 M3,8 L10,8 M3,12 L13,12" Stroke="#858585" StrokeThickness="1.1" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="Record"><Path Data="M4,4 L12,4 L12,12 L4,12 Z M8,6 A2,2 0 1,0 8,10 A2,2 0 1,0 8,6" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/></Button>
                                <Button Style="{StaticResource ToolButton}" Tag="MOBA"><Path Data="M4,12 L8,4 L12,12 M6,9 L10,9" Stroke="#858585" StrokeThickness="1.1" Fill="Transparent" Width="24" Height="24" Stretch="Uniform"/></Button>
                            </UniformGrid>

                            <TextBlock Text="SELECTED CONTROL" Foreground="#858585" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="1" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Key" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="W" Style="{StaticResource FieldBox}"/></Grid>
                                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Mode" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="SDK passthrough" Style="{StaticResource FieldBox}"/></Grid>
                                    <TextBlock Text="Mapping persistence is staged; controls here establish the UI and presets for the upcoming input bridge." Foreground="#858585" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Close_Click" Width="80" Style="{StaticResource DialogButton}" Margin="0,0,8,0"/>
                    <Button Content="Save" Click="Save_Click" Width="80" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
