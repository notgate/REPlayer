<Window x:Class="ReVM.AgentCenterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Center" Width="760" Height="520" MinWidth="680" MinHeight="440"
        WindowStyle="None" ResizeMode="CanResize" Background="#1E1E1E"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="28" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="BorderBrush" Color="#3C3C3C"/>
        <Style x:Key="VscodeToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#454545"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip" BasedOn="{StaticResource VscodeToolTip}"/>
        <Style x:Key="AgentButton" TargetType="Button">
            <Setter Property="Height" Value="26"/><Setter Property="MinWidth" Value="74"/><Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#454545"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="AgentText" TargetType="TextBox">
            <Setter Property="Height" Value="26"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="CaretBrush" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/><Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/><Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="7,5">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#333333"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#3A3A3A"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AgentCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="26"/><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1">
                                            <Grid>
                                                <ContentPresenter Margin="7,0,24,0" VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#CCCCCC"/>
                                                <Path Data="M0,0 L4,4 L8,0" Stroke="#858585" StrokeThickness="1" Width="8" Height="4"
                                                      HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#666666"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False">
                                <Border Background="#252526" BorderBrush="#454545" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220"><StackPanel IsItemsHost="True"/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.55"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Height" Value="24"/><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="#858585"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="0,0,1,1"/><Setter Property="FontSize" Value="9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="4,3">
                            <GridViewRowPresenter Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" Content="{TemplateBinding Content}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="RowBorder" Property="Background" Value="#252526"/></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="RowBorder" Property="Background" Value="#333333"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/><RowDefinition Height="112"/><RowDefinition Height="*"/><RowDefinition Height="116"/><RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#323233" BorderBrush="#454545" BorderThickness="0,0,0,1">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions>
                <TextBlock Text="Agent Center" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center" Margin="10,0"/>
                <Button Grid.Column="1" Click="Close_Click" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition Width="150"/><ColumnDefinition Width="72"/><ColumnDefinition Width="140"/><ColumnDefinition Width="74"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="AGENT" Foreground="#858585" FontSize="9" VerticalAlignment="Center"/>
                <TextBox x:Name="AgentIdBox" Grid.Column="1" Text="agent-1" Style="{StaticResource AgentText}"/>
                <TextBlock Grid.Column="2" Text="ACCESS" Foreground="#858585" FontSize="9" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="AccessCombo" Grid.Column="3" Style="{StaticResource AgentCombo}" SelectedIndex="0">
                    <ComboBoxItem Content="Observe (concurrent)" Tag="Observe"/>
                    <ComboBoxItem Content="Device control" Tag="DeviceControl"/>
                </ComboBox>
                <TextBlock Grid.Column="4" Text="TIMEOUT" Foreground="#858585" FontSize="9" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="TimeoutBox" Grid.Column="5" Text="30" Style="{StaticResource AgentText}"/>
                <TextBlock Grid.Column="6" Text="seconds" Foreground="#858585" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>

                <TextBlock Grid.Row="1" Text="PACKAGE" Foreground="#858585" FontSize="9" VerticalAlignment="Center" Margin="0,7,0,0"/>
                <TextBox x:Name="PackageBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource AgentText}" Margin="0,7,6,0" ToolTip="Optional Android package used for task evidence"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="ADB ARGUMENTS" Foreground="#858585" FontSize="9" VerticalAlignment="Center" Margin="10,7,0,0"/>
                <TextBox x:Name="CommandBox" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="3" Text="shell dumpsys activity activities" Style="{StaticResource AgentText}" Margin="0,7,0,0" ToolTip="Arguments passed directly to bundled ADB; no host shell is used"/>

                <TextBlock Grid.Row="2" Grid.ColumnSpan="5" x:Name="DeviceText" Foreground="#858585" FontFamily="Cascadia Mono, Consolas" FontSize="10" VerticalAlignment="Center" Margin="0,7,0,0"/>
                <Button Grid.Row="2" Grid.Column="5" Grid.ColumnSpan="2" Content="Queue agent" Click="Queue_Click" Style="{StaticResource AgentButton}" HorizontalAlignment="Right" Margin="0,7,0,0"/>
            </Grid>
        </Border>

        <ListView x:Name="RunList" Grid.Row="2" Background="#1E1E1E" Foreground="#CCCCCC" BorderThickness="0" SelectionChanged="RunList_SelectionChanged" FontSize="11">
            <ListView.View>
                <GridView AllowsColumnReorder="False">
                    <GridViewColumn Header="AGENT" Width="120" DisplayMemberBinding="{Binding AgentId}"/>
                    <GridViewColumn Header="ACCESS" Width="105" DisplayMemberBinding="{Binding Access}"/>
                    <GridViewColumn Header="STATUS" Width="92" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="STEP" Width="190" DisplayMemberBinding="{Binding Step}"/>
                    <GridViewColumn Header="DURATION" Width="82" DisplayMemberBinding="{Binding Duration}"/>
                    <GridViewColumn Header="RESULT" Width="145" DisplayMemberBinding="{Binding Summary}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="3" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Background="#171717">
            <TextBox x:Name="OutputBox" IsReadOnly="True" Background="#171717" Foreground="#B8B8B8" BorderThickness="0" Padding="9,7"
                     FontFamily="Cascadia Mono, Consolas" FontSize="10" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>

        <Border Grid.Row="4" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Open inbox" Click="OpenInbox_Click" Style="{StaticResource AgentButton}" Margin="0,0,6,0"/>
                <Button Grid.Column="2" Content="Open evidence" Click="OpenEvidence_Click" Style="{StaticResource AgentButton}" Margin="0,0,6,0"/>
                <Button Grid.Column="3" Content="Cancel selected" Click="Cancel_Click" Style="{StaticResource AgentButton}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
