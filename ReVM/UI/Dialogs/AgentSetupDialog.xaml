<Window x:Class="ReVM.AgentSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent setup" Width="820" Height="560" MinWidth="760" MinHeight="520"
        WindowStyle="None" ResizeMode="CanResize" Background="#1E1E1E"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="28" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries><ResourceDictionary Source="AgentCenterTheme.xaml"/></ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="BorderColor" Color="#3C3C3C"/>
        <Style x:Key="AgentButton" TargetType="Button">
            <Setter Property="Height" Value="28"/><Setter Property="MinWidth" Value="78"/><Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#454545"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="11"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3E3E3E"/><Setter TargetName="Bd" Property="BorderBrush" Value="#666666"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#252526"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Background" Value="#252526"/><Setter Property="Foreground" Value="#5A5A5A"/><Setter Property="Cursor" Value="Arrow"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="AgentText" TargetType="TextBox">
            <Setter Property="Height" Value="28"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="CaretBrush" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="7,4"/><Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="AgentPassword" TargetType="PasswordBox">
            <Setter Property="Height" Value="28"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="CaretBrush" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="7,4"/><Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="Background" Value="#252526"/><Setter Property="Padding" Value="7,5"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="Bd" Property="Background" Value="#333333"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="AgentCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="11"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><ToggleButton Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1"><Grid><ContentPresenter Margin="7,0,24,0" VerticalAlignment="Center" Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}" TextElement.Foreground="#CCCCCC"/><Path Data="M0,0 L4,4 L8,0" Stroke="#858585" StrokeThickness="1" Width="8" Height="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/></Grid></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="#666666"/></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template></ToggleButton><Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False"><Border Background="#252526" BorderBrush="#454545" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"><ScrollViewer MaxHeight="220"><StackPanel IsItemsHost="True"/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="9,7"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2D2D2D"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#37373D"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
      </ResourceDictionary>
    </Window.Resources>
    <Border BorderBrush="#454545" BorderThickness="1" Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="28"/><RowDefinition Height="*"/><RowDefinition Height="48"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#323233" BorderBrush="#454545" BorderThickness="0,0,0,1">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Text="Agent setup" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center" Margin="10,0"/><Button Grid.Column="1" Click="Close_Click" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True"><Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10"/></Button></Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="236"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
                    <Grid Margin="10"><Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="*"/><RowDefinition Height="36"/></Grid.RowDefinitions>
                        <TextBlock Text="CONFIGURED AGENTS" Foreground="#858585" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0"/>
                        <ListBox x:Name="ProfileList" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="ProfileList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate><DataTemplate><Grid><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="{Binding Name}" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Row="1" Text="{Binding ProviderDisplayName}" Foreground="#858585" FontSize="9" Margin="0,3,0,0"/></Grid></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                        <Button Grid.Row="2" Content="New agent" Style="{StaticResource AgentButton}" Click="NewAgent_Click" HorizontalAlignment="Stretch"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="30,24,30,20"><Grid.ColumnDefinitions><ColumnDefinition Width="116"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="42"/><RowDefinition Height="62"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Grid.ColumnSpan="2" Text="Provider profile" Foreground="#CCCCCC" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Text="Agent ID" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><TextBox x:Name="AgentIdBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource AgentText}"/>
                        <TextBlock Grid.Row="2" Text="Display name" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><TextBox x:Name="AgentNameBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource AgentText}"/>
                        <TextBlock Grid.Row="3" Text="Provider" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><ComboBox x:Name="ProviderCombo" Grid.Row="3" Grid.Column="1" Style="{StaticResource AgentCombo}" SelectionChanged="ProviderCombo_SelectionChanged"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                        <TextBlock Grid.Row="4" Text="Model" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><TextBox x:Name="ModelBox" Grid.Row="4" Grid.Column="1" Style="{StaticResource AgentText}"/>
                        <TextBlock Grid.Row="5" Text="API endpoint" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><TextBox x:Name="EndpointBox" Grid.Row="5" Grid.Column="1" Style="{StaticResource AgentText}"/>
                        <TextBlock Grid.Row="6" Text="API key" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center"/><PasswordBox x:Name="ApiKeyBox" Grid.Row="6" Grid.Column="1" Style="{StaticResource AgentPassword}" ToolTip="Blank keeps the key already stored in Windows Credential Manager"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="CredentialStatusText" Foreground="#858585" FontSize="10" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,4,0,0"/>
                        <Border Grid.Row="8" Grid.ColumnSpan="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Padding="12,10" VerticalAlignment="Top"><TextBlock Foreground="#858585" FontSize="10" TextWrapping="Wrap" Text="Each profile keeps only provider, model, and endpoint metadata in LocalAppData. API keys are stored per Windows user in Credential Manager and are never written to task evidence. OpenAI / ChatGPT, Claude, GLM, and OpenRouter models are supported through their native API shapes."/></Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
            <Border Grid.Row="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="10,9">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="StatusText" Text="Ready" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/><Button Grid.Column="1" x:Name="DeleteButton" Content="Delete" Click="Delete_Click" Style="{StaticResource AgentButton}" Margin="0,0,7,0"/><Button Grid.Column="2" x:Name="TestButton" Content="Test connection" Click="TestConnection_Click" Style="{StaticResource AgentButton}" Margin="0,0,7,0"/><Button Grid.Column="3" Content="Save" Click="Save_Click" Style="{StaticResource AgentButton}" Margin="0,0,7,0"/><Button Grid.Column="4" Content="Close" Click="Close_Click" Style="{StaticResource AgentButton}"/></Grid>
            </Border>
        </Grid>
    </Border>
</Window>
