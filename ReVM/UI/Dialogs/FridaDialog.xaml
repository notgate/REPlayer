<Window x:Class="ReVM.FridaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Frida Workbench" Height="720" Width="980"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="26" ResizeBorderThickness="4" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgPanel" Color="#252526"/>
        <SolidColorBrush x:Key="BgTitle" Color="#323233"/>
        <SolidColorBrush x:Key="BgHover" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="BgActive" Color="#37373D"/>
        <SolidColorBrush x:Key="BgPressed" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#858585"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="Danger" Color="#E81123"/>
        <SolidColorBrush x:Key="Success" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="Accent" Color="#007ACC"/>

        <Style x:Key="WinBtn" TargetType="Button"><Setter Property="Width" Value="34"/><Setter Property="Height" Value="26"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource Danger}"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="DialogTextBox" TargetType="TextBox"><Setter Property="Height" Value="28"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/><Setter Property="Padding" Value="8,5"/><Setter Property="FontSize" Value="12"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
        <Style x:Key="DialogButton" TargetType="Button"><Setter Property="Height" Value="28"/><Setter Property="MinWidth" Value="76"/><Setter Property="Padding" Value="12,0"/><Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontSize" Value="12"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgPressed}"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}"><Setter Property="Background" Value="{StaticResource BgActive}"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="VsScrollBar" TargetType="{x:Type ScrollBar}"><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#5A5A5A"/><Setter Property="BorderBrush" Value="#2D2D2D"/><Setter Property="SnapsToDevicePixels" Value="True"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="{x:Type ScrollBar}"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.Thumb><Thumb Background="{TemplateBinding Foreground}"><Thumb.Template><ControlTemplate TargetType="{x:Type Thumb}"><Border x:Name="ThumbBd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBd" Property="Background" Value="#707070"/></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBd" Property="Background" Value="#8A8A8A"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Thumb.Template></Thumb></Track.Thumb></Track></Border></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource VsScrollBar}"/>
        <Style TargetType="DataGrid"><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="#333333"/><Setter Property="RowBackground" Value="#252526"/><Setter Property="AlternatingRowBackground" Value="#202020"/><Setter Property="HeadersVisibility" Value="Column"/><Setter Property="CanUserAddRows" Value="False"/><Setter Property="CanUserDeleteRows" Value="False"/><Setter Property="CanUserResizeRows" Value="False"/><Setter Property="AutoGenerateColumns" Value="False"/><Setter Property="SelectionMode" Value="Single"/><Setter Property="SelectionUnit" Value="FullRow"/></Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="BorderBrush" Value="#3E3E3E"/><Setter Property="BorderThickness" Value="0,0,1,1"/><Setter Property="Padding" Value="8,5"/><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style TargetType="DataGridRow"><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2D2D2D"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#37373D"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style>
        <Style TargetType="DataGridCell"><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="8,3"/><Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="DataGridCell"><Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="26"/><RowDefinition Height="*"/><RowDefinition Height="56"/></Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource BgTitle}">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Path Data="M3,13 L8,3 L10,3 L13,13 L11,13 L10,10 L6,10 L5,13 Z M6.5,9 L9.5,9 L8,5.5 Z" Stroke="#858585" StrokeThickness="1.1" Width="13" Height="13" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="Frida Workbench" Foreground="{StaticResource TextPrimary}" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="  idle" Foreground="{StaticResource TextSecondary}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CloseBtn}" Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"><Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"/></Button>
            </Grid>

            <Grid Grid.Row="1" Margin="18,16,18,12">
                <Grid.ColumnDefinitions><ColumnDefinition Width="330"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="170"/></Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="SERVER" Style="{StaticResource FieldLabel}" Margin="0,0,0,10"/>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Frida server binary (x86_64 emulator)" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="BinaryPath" IsReadOnly="True" Style="{StaticResource DialogTextBox}"/><Button Grid.Column="1" Content="Browse" Click="Browse_Click" Width="72" Style="{StaticResource DialogButton}" Margin="8,0,0,0"/></Grid>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="88"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="ADB serial" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/><TextBox x:Name="SerialBox" Style="{StaticResource DialogTextBox}"/></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Port" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/><TextBox x:Name="PortBox" Style="{StaticResource DialogTextBox}" FontFamily="Cascadia Mono, Consolas"/></StackPanel></Grid>
                            <WrapPanel Margin="0,0,0,12"><Button Content="Push + Start" Click="PushStart_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/><Button Content="Forward" Click="Forward_Click" Style="{StaticResource DialogButton}" Margin="0,0,8,8"/><Button Content="Stop" Click="Stop_Click" Style="{StaticResource DialogButton}" Margin="0,0,8,8"/><Button Content="Check" Click="Check_Click" Style="{StaticResource DialogButton}" Margin="0,0,8,8"/></WrapPanel>
                        </StackPanel>
                        <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <StackPanel><TextBlock Text="Workflow" Foreground="{StaticResource TextPrimary}" FontSize="12" FontWeight="SemiBold"/><TextBlock Text="1. Select frida-server for Android x86_64.  2. Push + Start.  3. Forward tcp:27042.  4. Refresh processes or attach with frida-tools from the host." TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,5,0,0"/></StackPanel>
                        </Border>
                        <DataGrid x:Name="ProcessesGrid" Grid.Row="3" ItemsSource="{Binding Processes}" SelectionChanged="ProcessesGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="58"/>
                                <DataGridTextColumn Header="TYPE" Binding="{Binding Kind}" Width="62"/>
                                <DataGridTextColumn Header="NAME / PACKAGE" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="14" Margin="0,0,0,10">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="TARGET" Style="{StaticResource FieldLabel}"/><TextBox x:Name="TargetBox" Style="{StaticResource DialogTextBox}" Margin="0,8,0,0" ToolTip="PID, process name, or package name"/></StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="10,0,0,0"><Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource DialogButton}" Margin="0,0,8,0"/><Button Content="Attach" Click="Attach_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/><Button Content="Spawn" Click="Spawn_Click" Style="{StaticResource DialogButton}"/></WrapPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="2" Grid.Row="1">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="210"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="12">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="SCRIPT TEMPLATES" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/><DataGrid x:Name="ScriptsGrid" Grid.Row="1" ItemsSource="{Binding Scripts}" SelectionChanged="ScriptsGrid_SelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/></DataGrid.Columns></DataGrid></Grid>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="12">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="SCRIPT EDITOR" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/><TextBox x:Name="ScriptEditor" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" FontSize="12" Style="{StaticResource DialogTextBox}" Height="Auto" VerticalContentAlignment="Top"/></Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="12" Margin="0,10,0,0">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="EVENT LOG" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/><DataGrid x:Name="LogGrid" Grid.Row="1" ItemsSource="{Binding Events}"><DataGrid.Columns><DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="82"/><DataGridTextColumn Header="LEVEL" Binding="{Binding Level}" Width="70"/><DataGridTextColumn Header="MESSAGE" Binding="{Binding Message}" Width="*"/></DataGrid.Columns></DataGrid></Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="16,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Copy frida command" Click="CopyCommand_Click" Width="142" Style="{StaticResource DialogButton}" Margin="0,0,8,0"/><Button Content="Close" Click="Close_Click" Width="80" Style="{StaticResource DialogButton}"/></StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
