<Window x:Class="ReVM.AgentInboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Center Inbox" Width="940" Height="590" MinWidth="760" MinHeight="480"
        WindowStyle="None" ResizeMode="CanResize" Background="#1E1E1E" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <WindowChrome.WindowChrome><WindowChrome CaptionHeight="28" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0"/></WindowChrome.WindowChrome>
    <Window.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries><ResourceDictionary Source="AgentCenterTheme.xaml"/></ResourceDictionary.MergedDictionaries>
        <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Height" Value="26"/><Setter Property="MinWidth" Value="76"/><Setter Property="Padding" Value="10,0"/><Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#454545"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontSize" Value="11"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3E3E3E"/><Setter TargetName="Bd" Property="BorderBrush" Value="#666666"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#252526"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="ComboBoxItem"><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="Background" Value="#252526"/><Setter Property="Padding" Value="7,5"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="Bd" Property="Background" Value="#333333"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="FilterCombo" TargetType="ComboBox"><Setter Property="Height" Value="26"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="11"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><ToggleButton Focusable="False" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Bd" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"><Grid><ContentPresenter Margin="7,0,24,0" VerticalAlignment="Center" Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" TextElement.Foreground="#CCCCCC"/><Path Data="M0,0 L4,4 L8,0" Stroke="#858585" StrokeThickness="1" Width="8" Height="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/></Grid></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="#666666"/></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template></ToggleButton><Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False"><Border Background="#252526" BorderBrush="#454545" BorderThickness="1" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"><ScrollViewer MaxHeight="220"><StackPanel IsItemsHost="True"/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="GridViewColumnHeader"><Setter Property="Height" Value="24"/><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="#858585"/><Setter Property="BorderBrush" Value="#3C3C3C"/><Setter Property="BorderThickness" Value="0,0,1,1"/><Setter Property="FontSize" Value="9"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="GridViewColumnHeader"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="ListViewItem"><Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="#2A2A2A"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListViewItem"><Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="4,3"><GridViewRowPresenter Columns="{Binding View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}" Content="{TemplateBinding Content}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#252526"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#333333"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
      </ResourceDictionary>
    </Window.Resources>
    <Border BorderBrush="#454545" BorderThickness="1">
        <Grid><Grid.RowDefinitions><RowDefinition Height="28"/><RowDefinition Height="42"/><RowDefinition Height="*"/><RowDefinition Height="190"/><RowDefinition Height="36"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#323233" BorderBrush="#454545" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><TextBlock Text="Agent Center Inbox" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center" Margin="10,0"/><Button Grid.Column="1" Click="Close_Click" Background="Transparent" BorderThickness="0" WindowChrome.IsHitTestVisibleInChrome="True"><Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10"/></Button></Grid></Border>
            <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,0,1" Padding="9,7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="STATUS" Foreground="#858585" FontSize="9" VerticalAlignment="Center" Margin="0,0,8,0"/><ComboBox x:Name="FilterCombo" Grid.Column="1" Style="{StaticResource FilterCombo}" SelectionChanged="FilterCombo_SelectionChanged"><ComboBoxItem Content="All tasks" Tag="All" IsSelected="True"/><ComboBoxItem Content="Pending" Tag="Pending"/><ComboBoxItem Content="Running" Tag="Running"/><ComboBoxItem Content="Completed" Tag="Completed"/><ComboBoxItem Content="Incomplete" Tag="Incomplete"/><ComboBoxItem Content="Failed" Tag="Failed"/><ComboBoxItem Content="Cancelled" Tag="Cancelled"/></ComboBox><TextBlock x:Name="HarnessText" Grid.Column="2" Foreground="#858585" FontFamily="Cascadia Mono, Consolas" FontSize="10" VerticalAlignment="Center" Margin="12,0"/><Button Grid.Column="3" Content="Refresh" Click="Refresh_Click" Style="{StaticResource ActionButton}"/></Grid></Border>
            <ListView x:Name="TaskList" Grid.Row="2" Background="#1E1E1E" BorderThickness="0" SelectionChanged="TaskList_SelectionChanged"><ListView.View><GridView AllowsColumnReorder="False"><GridViewColumn Header="STATUS" Width="92" DisplayMemberBinding="{Binding Status}"/><GridViewColumn Header="AGENT" Width="155" DisplayMemberBinding="{Binding AgentName}"/><GridViewColumn Header="PROVIDER" Width="150" DisplayMemberBinding="{Binding Provider}"/><GridViewColumn Header="CREATED" Width="136" DisplayMemberBinding="{Binding Created}"/><GridViewColumn Header="TASK" Width="360" DisplayMemberBinding="{Binding PromptSummary}"/></GridView></ListView.View></ListView>
            <Border Grid.Row="3" Background="#171717" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="10,8"><Grid><Grid.RowDefinitions><RowDefinition Height="20"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="REPORT" Foreground="#858585" FontSize="9" FontWeight="Bold"/><TextBox x:Name="ReportBox" Grid.Row="1" IsReadOnly="True" Background="#171717" Foreground="#B8B8B8" BorderThickness="0" FontFamily="Cascadia Mono, Consolas" FontSize="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/></Grid></Border>
            <Border Grid.Row="4" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="9,5"><TextBlock x:Name="StatusText" Foreground="#858585" FontSize="10" VerticalAlignment="Center"/></Border>
        </Grid>
    </Border>
</Window>
