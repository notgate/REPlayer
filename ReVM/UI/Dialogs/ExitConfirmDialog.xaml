<Window x:Class="ReVM.ExitConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exit REPlayer" Height="178" Width="410"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="28" ResizeBorderThickness="0" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgTitle" Color="#252526"/>
        <SolidColorBrush x:Key="BgFooter" Color="#202020"/>
        <SolidColorBrush x:Key="BgButton" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgButtonHover" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="BgButtonPressed" Color="#252526"/>
        <SolidColorBrush x:Key="BgExit" Color="#37373D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#858585"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="Danger" Color="#E81123"/>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource Danger}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#B10F1F"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Width" Value="86"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="{StaticResource BgButton}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgButtonHover}"/><Setter TargetName="Bd" Property="BorderBrush" Value="#5A5A5A"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgButtonPressed}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExitButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="{StaticResource BgExit}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="94"/>
                <RowDefinition Height="54"/>
            </Grid.RowDefinitions>

            <!-- LDPlayer-style compact Qt title band -->
            <Grid Grid.Row="0" Background="{StaticResource BgTitle}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="38"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Exit REPlayer" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center" Margin="12,0,0,1"/>
                <Button Grid.Column="1" Style="{StaticResource ChromeButton}" Click="Cancel_Click" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1.05" Width="10" Height="10" Stretch="Uniform"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="26,20,26,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Width="28" Height="28" VerticalAlignment="Top">
                    <Path Data="M10,3 L10,10 M6.2,5.2 A6,6 0 1,0 13.8,5.2" Stroke="#CCCCCC" StrokeThickness="1.45" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <TextBlock Text="Exit REPlayer?" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,7"/>
                    <TextBlock Text="Android will be stopped and the current emulator session will close." Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="17"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource BgFooter}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Cancel" Style="{StaticResource DialogButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
                        <Button Content="Exit" Style="{StaticResource ExitButton}" Click="Exit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
