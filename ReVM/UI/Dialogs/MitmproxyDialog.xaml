<Window x:Class="ReVM.MitmproxyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MITM Proxy" Height="640" Width="900"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="26" ResizeBorderThickness="4" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgPanel" Color="#252526"/>
        <SolidColorBrush x:Key="BgTitle" Color="#323233"/>
        <SolidColorBrush x:Key="BgCard" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="BgHover" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="BgActive" Color="#37373D"/>
        <SolidColorBrush x:Key="BgPressed" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#858585"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="Danger" Color="#E81123"/>
        <SolidColorBrush x:Key="Ok" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="Warn" Color="#DCDCAA"/>

        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/><Setter Property="Height" Value="26"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgPressed}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="CloseChromeBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource Danger}"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="LdTextBox" TargetType="TextBox"><Setter Property="Height" Value="28"/><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/><Setter Property="Padding" Value="8,5"/><Setter Property="FontSize" Value="12"/></Style>
        <Style x:Key="DialogButton" TargetType="Button"><Setter Property="Height" Value="28"/><Setter Property="MinWidth" Value="104"/><Setter Property="Padding" Value="18,0"/><Setter Property="Background" Value="#2D2D2D"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontSize" Value="12"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Bd" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="{StaticResource BgPressed}"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Opacity" Value="0.45"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}"><Setter Property="Background" Value="{StaticResource BgActive}"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="VsScrollBar" TargetType="{x:Type ScrollBar}"><Setter Property="Background" Value="#1E1E1E"/><Setter Property="Foreground" Value="#5A5A5A"/><Setter Property="BorderBrush" Value="#2D2D2D"/><Setter Property="SnapsToDevicePixels" Value="True"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="{x:Type ScrollBar}"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.Thumb><Thumb Background="{TemplateBinding Foreground}"><Thumb.Template><ControlTemplate TargetType="{x:Type Thumb}"><Border x:Name="ThumbBd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2"/><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ThumbBd" Property="Background" Value="#707070"/></Trigger><Trigger Property="IsDragging" Value="True"><Setter TargetName="ThumbBd" Property="Background" Value="#8A8A8A"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Thumb.Template></Thumb></Track.Thumb></Track></Border></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource VsScrollBar}"/>

        <Style x:Key="MitmGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgMain}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#202020"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#323233"/><Setter Property="Foreground" Value="{StaticResource TextSecondary}"/><Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/><Setter Property="BorderThickness" Value="0,0,1,1"/><Setter Property="Padding" Value="8,5"/><Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style TargetType="DataGridRow"><Setter Property="Background" Value="#252526"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="BorderBrush" Value="#333333"/><Setter Property="BorderThickness" Value="0,0,0,1"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2D2D2D"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#37373D"/></Trigger></Style.Triggers></Style>
        <Style TargetType="DataGridCell"><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="6,3"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/><Setter Property="FocusVisualStyle" Value="{x:Null}"/></Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="26"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="96"/></Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource BgTitle}" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="MITM Proxy Interception" Foreground="{StaticResource TextPrimary}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Grid.Column="1" Style="{StaticResource CloseChromeBtn}" Click="Close_Click" WindowChrome.IsHitTestVisibleInChrome="True"><Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="#CCCCCC" StrokeThickness="1" Width="10" Height="10" Stretch="Uniform"/></Button>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="94"/><ColumnDefinition Width="90"/><ColumnDefinition Width="96"/><ColumnDefinition Width="120"/><ColumnDefinition Width="96"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Listen port" Style="{StaticResource FieldLabel}" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="PortBox" Grid.Column="1" Text="8080" Style="{StaticResource LdTextBox}" FontFamily="Cascadia Mono, Consolas"/>
                    <TextBlock Text="Web port" Style="{StaticResource FieldLabel}" Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBox x:Name="WebPortBox" Grid.Column="3" Text="8081" Style="{StaticResource LdTextBox}" FontFamily="Cascadia Mono, Consolas"/>
                    <TextBlock Text="Upstream" Style="{StaticResource FieldLabel}" Grid.Column="4" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBox x:Name="UpstreamBox" Grid.Column="5" Style="{StaticResource LdTextBox}" ToolTip="Optional, e.g. http://127.0.0.1:8888 or socks5://127.0.0.1:9050"/>

                    <WrapPanel Grid.Row="1" Grid.ColumnSpan="6" Margin="0,10,0,0">
                        <Button x:Name="StartButton" Content="Start mitmweb" Style="{StaticResource PrimaryButton}" Click="Start_Click"/>
                        <Button x:Name="StopButton" Content="Stop" Style="{StaticResource DialogButton}" Click="Stop_Click" Margin="8,0,0,8" IsEnabled="False"/>
                        <Button Content="Set Android proxy" Style="{StaticResource DialogButton}" Click="SetProxy_Click" Margin="18,0,0,8"/>
                        <Button Content="Clear proxy" Style="{StaticResource DialogButton}" Click="ClearProxy_Click" Margin="8,0,0,8"/>
                        <Button Content="Open mitmweb" Style="{StaticResource DialogButton}" Click="OpenWeb_Click" Margin="18,0,0,8"/>
                        <Button Content="CA help" Style="{StaticResource DialogButton}" Click="CaHelp_Click" Margin="8,0,0,8"/>
                        <Button Content="Clear rows" Style="{StaticResource DialogButton}" Click="ClearRows_Click" Margin="18,0,0,8"/>
                    </WrapPanel>

                    <TextBlock x:Name="StatusText" Grid.Row="2" Grid.ColumnSpan="6" Foreground="{StaticResource TextSecondary}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="14,12,14,8">
                <DataGrid x:Name="CaptureGrid" Style="{StaticResource MitmGrid}" ItemsSource="{Binding CaptureRows}" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Resources><Style TargetType="ScrollBar" BasedOn="{StaticResource VsScrollBar}"/></DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIME" Binding="{Binding Timestamp}" Width="92"/>
                        <DataGridTextColumn Header="METHOD" Binding="{Binding Method}" Width="70"/>
                        <DataGridTextColumn Header="HOST" Binding="{Binding Host}" Width="180"/>
                        <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*"/>
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="70"/>
                        <DataGridTextColumn Header="NOTES" Binding="{Binding Notes}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Row="3" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="14,10">
                <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" TextWrapping="Wrap">
                    <Run Foreground="{StaticResource Warn}" Text="Emulator proxy target: "/><Run Text="Android emulator traffic should point at host alias 10.0.2.2:&lt;listen-port&gt;. "/>
                    <Run Text="After setting the proxy, open http://mitm.it in Android and install the mitmproxy certificate. Android 7+ apps that do not trust user CAs still need a network-security-config, repack/patch, or system CA placement for HTTPS interception."/>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
